# Скопируйте в .env и заполните значения. Файл .env в git не коммитить.

# Обязательно: секретный ключ Django (сгенерируйте новый для продакшена).
# Пример: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Режим отладки: true / false (в продакшене всегда false)
DEBUG=false
USE_WHITENOISE=true
# Список хостов через запятую, без пробелов вокруг запятых (для локалки: 127.0.0.1,localhost)
ALLOWED_HOSTS=127.0.0.1,localhost
# За nginx с TLS: доверять X-Forwarded-* и явные origin для форм (админка, логин)
BEHIND_REVERSE_PROXY=false
# Публичный URL схемой и хостом, через запятую: https://example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=

# Конфигурация базы данных
# Тип БД: sqlite (по умолчанию) или postgresql
DATABASE_ENGINE=postgresql

# Настройки PostgreSQL (используются только при DATABASE_ENGINE=postgresql)
DATABASE_NAME=vizoology
DATABASE_USER=vizoology_user
DATABASE_PASSWORD=vizoology_password
DATABASE_HOST=localhost
# При `docker compose up -d db` из этого репозитория Postgres доступен на хосте как 65432 (см. docker-compose.yml).
DATABASE_PORT=5432

# Имя/путь файла SQLite относительно корня проекта (используется только при DATABASE_ENGINE=sqlite)
# DATABASE_PATH=db.sqlite3

# Локализация (необязательно; значения по умолчанию en-us и UTC)
# LANGUAGE_CODE=en-us
# TIME_ZONE=UTC

# Префикс URL для статики (необязательно)
# STATIC_URL=static/

# Префикс URL для медиафайлов (файловая директория — ./media от корня проекта)
# MEDIA_URL=media/

# --- Confluence / Atlassian Configuration ---
# Базовый URL Confluence (например: https://your-site.atlassian.net/wiki/)
CONFLUENCE_BASE_URL=

# Ключ пространства не задаётся в .env: указывайте при индексации (UI / форма), sync_pages --space-key и т.п.

# Email для аутентификации в Atlassian
CONFLUENCE_USERNAME=

# API токен для Atlassian (создается в Account Settings -> Security -> API tokens)
CONFLUENCE_API_TOKEN=

# --- Local Embeddings ---
# Многоязычная локальная модель для векторизации документации.
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-small
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSIONS=384

# --- DeepSeek Generation (Chat Completions, OpenAI-совместимый API) ---
# Используется только для генерации финального ответа по найденным чанкам.
# Ключ и модели — в личном кабинете https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_NAME=deepseek-chat
# При необходимости другого эндпоинта:
# DEEPSEEK_API_BASE=https://api.deepseek.com

# --- RAG ---
# Минимальный score лучшего найденного фрагмента. Если ниже, LLM не вызывается.
RAG_MIN_SCORE=0.55

# --- Parser (Excel) ---
# Буква колонки с вопросами по умолчанию, если в коде/команде не указано иное (A–Z, AA…).
PARSER_DEFAULT_QUESTION_COLUMN_LETTER=Q
